{
  "expo": {
    "name": "Myntra",
    "slug": "myntra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/myntra.jpg",
    "scheme": "myntra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/myntra.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/myntra.jpg"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/myntra.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.myntra.clone"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/myntra-fav.webp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/myntra.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/myntra.jpg",
          "color": "#ff3f6c"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f9b38ac7-9f10-4d68-8789-b6b79a4410f5"
      }
    }
  }
}
